# Normalize line endings across Windows, macOS, and Linux.
* text=auto eol=lf

# Godot / game assets
*.gd text eol=lf
*.tscn text eol=lf
*.godot text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mdc text eol=lf
*.svg text eol=lf
*.import binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.wav binary
*.ogg binary
